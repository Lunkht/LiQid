<?xml version="1.0" encoding="utf-8"?>
<!--
    CONTRÔLE CARTE — Ligne avec icône + label + switch
    Réutilisé pour : geler, paiements en ligne, sans contact, DAB
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <!-- Icône -->
    <FrameLayout
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_transaction_icon">

        <ImageView
            android:id="@+id/iv_control_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            app:tint="@color/text_secondary"
            tools:src="@drawable/ic_freeze"/>

    </FrameLayout>

    <!-- Label + sous-label -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginHorizontal="14dp">

        <TextView
            android:id="@+id/tv_control_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/liqid_text_primary"
            android:textSize="15sp"
            tools:text="Geler la carte"/>

        <TextView
            android:id="@+id/tv_control_sublabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="?attr/liqid_text_secondary"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="Bloquer tous les paiements"/>

    </LinearLayout>

    <!-- Switch -->
    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switch_control"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:trackTint="@drawable/selector_switch_track"
        app:thumbTint="@color/text_primary"/>

</LinearLayout>
