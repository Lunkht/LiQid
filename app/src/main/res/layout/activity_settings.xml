<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/liqid_bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/liqid_bg_primary"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Paramètres"
            app:titleTextColor="?attr/liqid_text_primary"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Section Compte -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="COMPTE"
                android:textColor="?attr/liqid_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                style="@style/Widget.Banking.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_personal_info"/>

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_iban"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"/>

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_documents"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"/>

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_profile_link"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"/>

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_currency"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Section Sécurité -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="SÉCURITÉ"
                android:textColor="?attr/liqid_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                style="@style/Widget.Banking.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_pin"/>

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_biometric"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"/>

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_devices"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Section Apparence et Langue -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="PERSONNALISATION"
                android:textColor="?attr/liqid_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                style="@style/Widget.Banking.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/setting_theme_selector"/>

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_language"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"/>

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_notifications"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Section Confidentialité -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="CONFIDENTIALITÉ"
                android:textColor="?attr/liqid_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                style="@style/Widget.Banking.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/setting_hide_balance"/>

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/setting_incognito"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Section À propos -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="À PROPOS"
                android:textColor="?attr/liqid_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                style="@style/Widget.Banking.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_tos"/>

                    <include layout="@layout/item_profile_menu"
                        android:id="@+id/menu_privacy"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="40dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/logo"
                    app:tint="?attr/liqid_text_secondary"
                    android:alpha="0.5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="LiQid Banking"
                    android:textColor="?attr/liqid_text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:alpha="0.5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Version 1.0.0 (Build 2025)"
                    android:textColor="?attr/liqid_text_secondary"
                    android:textSize="11sp"
                    android:alpha="0.5"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/layout_custom_bottom_nav"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
