<?xml version="1.0" encoding="utf-8"?>
<!--
    SUCCÈS DE TRANSACTION — Animation Lottie (check vert) + résumé
    Affiché après un virement confirmé
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/liqid_bg_primary"
    android:gravity="center_horizontal"
    android:paddingHorizontal="@dimen/screen_margin"
    android:paddingBottom="48dp">

    <!-- Spacer -->
    <View android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Animation check (cercle vert animé) -->
    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_success_circle">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check_circle"
            app:tint="@color/text_on_accent"/>

    </FrameLayout>

    <!-- Titre succès -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Virement envoyé !"
        android:textColor="?attr/liqid_text_primary"
        android:textSize="26sp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Sous-titre -->
    <TextView
        android:id="@+id/tv_success_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="?attr/liqid_text_secondary"
        android:textSize="15sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        tools:text="500,00 € ont été envoyés\nà Alpha Barry"/>

    <!-- Résumé transaction -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        style="@style/Widget.Banking.Card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Montant"
                    android:textColor="@color/text_secondary" android:textSize="14sp"/>
                <TextView android:id="@+id/tv_summary_amount"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" tools:text="500,00 €"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Destinataire"
                    android:textColor="@color/text_secondary" android:textSize="14sp"/>
                <TextView android:id="@+id/tv_summary_recipient"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    tools:text="Alpha Barry"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Référence"
                    android:textColor="@color/text_secondary" android:textSize="14sp"/>
                <TextView android:id="@+id/tv_summary_ref"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary" android:textSize="13sp"
                    android:fontFamily="monospace" tools:text="VLB-2025-06-001"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Date"
                    android:textColor="@color/text_secondary" android:textSize="14sp"/>
                <TextView android:id="@+id/tv_summary_date"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    tools:text="24 juin 2025 · 14:32"/>
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Spacer -->
    <View android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Partager le reçu -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_share_receipt"
        style="@style/Widget.Banking.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:text="Partager le reçu"
        app:icon="@drawable/ic_share"
        app:iconTint="@color/text_primary"
        app:iconGravity="textStart"/>

    <!-- Retour accueil -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_go_home"
        style="@style/Widget.Banking.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:layout_marginTop="12dp"
        android:text="Retour à l'accueil"/>

</LinearLayout>
