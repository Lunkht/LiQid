<?xml version="1.0" encoding="utf-8"?>
<!--
    BOTTOM SHEET — Recharger le compte (Top-up)
    Choix du montant rapide + saisie libre + méthode de paiement
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="40dp">

    <!-- Handle -->
    <View
        android:layout_width="@dimen/sheet_handle_width"
        android:layout_height="@dimen/sheet_handle_height"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_sheet_handle"/>

    <!-- Titre -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/screen_margin"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:text="Recharger le compte"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Montants rapides -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/screen_margin"
        android:layout_marginBottom="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_amount_20"
            style="@style/Widget.Banking.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="20 €"
            android:textSize="14sp"
            app:cornerRadius="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_amount_50"
            style="@style/Widget.Banking.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="50 €"
            android:textSize="14sp"
            app:cornerRadius="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_amount_100"
            style="@style/Widget.Banking.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="100 €"
            android:textSize="14sp"
            app:cornerRadius="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_amount_500"
            style="@style/Widget.Banking.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="500 €"
            android:textSize="14sp"
            app:cornerRadius="10dp"/>

    </LinearLayout>

    <!-- Montant libre -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_topup_amount"
        style="@style/Widget.Banking.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/screen_margin"
        android:hint="Autre montant"
        app:startIconDrawable="@drawable/ic_euro"
        app:startIconTint="@color/text_tertiary"
        app:suffixText="EUR"
        app:suffixTextColor="@color/text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_topup_amount"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Méthode de paiement -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/screen_margin"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        android:text="Méthode de paiement"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:letterSpacing="0.05"
        android:textAllCaps="true"/>

    <!-- Option carte bancaire -->
    <LinearLayout
        android:id="@+id/method_card"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/screen_margin"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_transaction_icon">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_card"
                app:tint="@color/text_secondary"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carte bancaire"
                android:textColor="@color/text_primary"
                android:textSize="15sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Visa •••• 4721"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/radio_card"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_radio_selected"
            app:tint="@color/accent_orange"/>

    </LinearLayout>

    <!-- Option virement bancaire -->
    <LinearLayout
        android:id="@+id/method_bank_transfer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/screen_margin"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_transaction_icon">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bank"
                app:tint="@color/text_secondary"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Virement bancaire"
                android:textColor="@color/text_primary"
                android:textSize="15sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Délai : 1-2 jours ouvrés"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/radio_bank"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_radio_unselected"
            app:tint="@color/text_tertiary"/>

    </LinearLayout>

    <!-- Bouton confirmer -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm_topup"
        style="@style/Widget.Banking.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:layout_marginHorizontal="@dimen/screen_margin"
        android:layout_marginTop="24dp"
        android:text="Recharger"
        app:icon="@drawable/ic_topup"
        app:iconTint="@color/text_on_accent"
        app:iconGravity="textStart"/>

</LinearLayout>
