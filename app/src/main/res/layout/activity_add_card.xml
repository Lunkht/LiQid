<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/liqid_bg_primary">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Ajouter une carte"
        app:titleTextColor="?attr/liqid_text_primary"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/liqid_text_primary"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Banking.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nom du titulaire">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_cardholder"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="textPersonName"
                android:textColor="?attr/liqid_text_primary"
                android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Banking.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Type de carte"
            app:endIconMode="dropdown_menu">

            <AutoCompleteTextView
                android:id="@+id/tv_plan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:textColor="?attr/liqid_text_primary"
                android:textSize="16sp"
                android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit_card"
            style="@style/Widget.Banking.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="Ajouter la carte"/>

    </LinearLayout>

</LinearLayout>
